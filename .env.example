APP_NAME=Laravel
APP_ENV=local
APP_KEY=test1234
APP_DEBUG=true
APP_URL=http://localhost
# Frontend origin for CORS (e.g. Vite dev server or production client URL)
# FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Filament /login: max wrong passwords per email+IP before lockout; lockout window in seconds
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_DECAY_SECONDS=120

# Outgoing HTTPS (Slack, Pusher REST, etc.): Composer CA bundle by default — fixes cURL error 60 on Windows when php.ini has no curl.cainfo.
# Optional: absolute path to a PEM file, or "false" to disable TLS verification (debug only).
# HTTP_CLIENT_VERIFY=

# Broadcasting: "pusher" for real-time; "log" to disable (bookings still work, no WebSocket)
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local

# Pusher (broadcasting driver)
# If you're using Pusher.com, you can usually leave PUSHER_HOST empty and just set the cluster + credentials.
PUSHER_APP_ID=marcelinos-app
PUSHER_APP_KEY=local-key
PUSHER_APP_SECRET=local-secret
PUSHER_APP_CLUSTER=ap1
PUSHER_HOST=api-ap1.pusher.com
PUSHER_PORT=443
PUSHER_SCHEME=https
# Optional: override the TLS port used by websocket clients.
PUSHER_WSS_PORT=443
QUEUE_CONNECTION=database
# Process queued jobs (including Slack) in dev: php artisan queue:work
# In production, run a queue worker or Laravel Horizon so notifications are delivered.

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=failover
MAIL_FAILOVER_MAILERS=smtp,smtp_backup,log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_BACKUP_SCHEME=null
MAIL_BACKUP_HOST=
MAIL_BACKUP_PORT=
MAIL_BACKUP_USERNAME=
MAIL_BACKUP_PASSWORD=
MAIL_BACKUP_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_BOOKING_CC_ADDRESS=marcelinosresorthotel@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

API_KEY=

# Cloudflare Turnstile (server verify). Set secret from Cloudflare dashboard; frontend uses VITE_TURNSTILE_SITE_KEY.
# When unset, verification is skipped except in production (production without key returns validation error).
TURNSTILE_SECRET_KEY=

# Email verification for public bookings (signed link TTL + stale intent cleanup)
BOOKING_VERIFY_EMAIL_TTL_HOURS=72
BOOKING_PENDING_VERIFICATION_PRUNE_HOURS=48

# Slack (laravel/slack-notification-channel + config/services.php slack.notifications)
# Bot token: OAuth with chat:write; channel: ID like C01234567 or #bookings
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
# Set true in staging/production to send booking lifecycle + Xendit failure alerts to Slack
SLACK_BOOKING_ALERTS_ENABLED=false
# Uncaught server/API exceptions (5xx) + optional front-end reports to Slack (same bot token; optional channel override)
# SLACK_ERROR_ALERTS_ENABLED=false
# Optional: send error alerts to a dedicated channel (defaults to SLACK_BOT_USER_DEFAULT_CHANNEL)
# SLACK_ERROR_ALERTS_CHANNEL=
# SLACK_ERROR_ALERT_THROTTLE_MINUTES=5
# SLACK_CLIENT_ERROR_THROTTLE_MINUTES=2
# Optional: also notify on ignored Xendit webhook statuses (e.g. EXPIRED). Default false (noisy).
# SLACK_XENDIT_NOTIFY_NONPAID_EVENTS=false

# Booking cancel/reschedule OTP (email): after N sends, wait cooldown seconds
# BOOKING_ACTION_OTP_MAX_SENDS=3
# BOOKING_ACTION_OTP_COOLDOWN_SECONDS=60

# Dynamic cancellation deduction percentage (0-100), used by cancellation policy/refund breakdown.
PAYMENT_CANCELLATION_FEE_PERCENT=30

# Hostinger hosting plan expiry date for Filament settings dashboard (YYYY-MM-DD).
HOSTINGER_PLAN_EXPIRES_AT=

# Refund notifications on rescheduled bookings:
# - Eligible notice is optional and only used for partial/review states.
REFUND_GUEST_ELIGIBLE_ENABLED=false
# - Completed notice is used when payment_status becomes refunded.
REFUND_GUEST_COMPLETED_ENABLED=true
# - Staff alert is used when payment_status becomes refunded.
REFUND_STAFF_ALERT_ENABLED=true
# Comma-separated emails for refund operations alerts.
REFUND_STAFF_RECIPIENTS=

# Google Sheets booking sync
# Enable to sync bookings into status tabs (Unpaid/Partial/Paid/Complete/Checked in/Cancel)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
# Example: storage/app/google-credentials.json
GOOGLE_SHEETS_CREDENTIALS_PATH=storage/app/google-credentials.json
GOOGLE_SHEETS_TAB_UNPAID=Unpaid
GOOGLE_SHEETS_TAB_PARTIAL=Partial
GOOGLE_SHEETS_TAB_PAID=Paid
GOOGLE_SHEETS_TAB_COMPLETE=Complete
GOOGLE_SHEETS_TAB_CHECKED_IN=Checked in
GOOGLE_SHEETS_TAB_CANCEL=Cancel
# Optional for the existing "rescheduled" status in bookings
GOOGLE_SHEETS_TAB_RESCHEDULED=Rescheduled
